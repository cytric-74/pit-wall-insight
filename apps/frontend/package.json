{
  "name": "@pit-wall-insight/frontend",
  "version": "0.0.0",
  "private": true,
  "description": "React + TypeScript analytics client. Application shell only — no dashboard content yet.",
  "type": "module",
  "scripts": {
    "build": "tsc --noEmit -p tsconfig.json && vite build",
    "dev": "vite",
    "lint": "eslint . --no-error-on-unmatched-pattern",
