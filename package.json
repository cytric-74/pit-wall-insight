{
  "name": "pit-wall-insight",
  "version": "0.0.0",
  "private": true,
  "description": "Formula One analytics platform monorepo — foundation workspace (no application code yet).",
  "license": "UNLICENSED",
  "packageManager": "pnpm@11.13.1",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "clean": "turbo run clean",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepare": "husky",
    "infra:up": "docker compose up -d",
    "infra:down": "docker compose down",
    "infra:logs": "docker compose logs -f",
    "infra:reset": "docker compose down -v"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@pit-wall-insight/config": "workspace:*",
    "eslint": "^10.7.0",
    "eslint-config-prettier": "^10.1.8",
    "husky": "^9.1.7",
    "lint-staged": "^15.5.2",
    "prettier": "^3.9.5",
    "turbo": "^2.10.5",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.64.0"
  }
}
