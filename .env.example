# Copy this file to .env and fill in real values.
# Never commit the real .env file.
# See docs/11_DEPLOYMENT.md for the authoritative list of variables per environment.

# --- Shared ---
ENVIRONMENT=development

# --- Frontend (apps/frontend) ---
VITE_API_URL=http://localhost:8000/api/v1
VITE_APP_NAME="Pit Wall Insight"
VITE_ENVIRONMENT=development

# --- Backend (apps/backend) ---
# Raw/bronze layer connection
DATABASE_URL=postgresql://pitwall:pitwall@localhost:5432/pit_wall_insight_raw
# Analytics/gold layer connection consumed by the API
ANALYTICS_DATABASE_URL=postgresql://pitwall:pitwall@localhost:5432/pit_wall_insight_analytics
SECRET_KEY=change-me-in-production
API_VERSION=v1
LOG_LEVEL=info
# Comma-separated origins allowed to call this API from a browser (CORS).
CORS_ORIGINS=http://localhost:5173,http://localhost:4173

# --- Data pipeline (apps/ingestion, warehouse/dbt) ---
FASTF1_CACHE=./.fastf1_cache
DBT_TARGET=dev
PIPELINE_VERSION=0.1.0
# Ergast's own API was retired in 2024; Jolpica-F1 is the byte-compatible,
# no-key successor used for historical standings/results/calendar data.
JOLPICA_BASE_URL=https://api.jolpi.ca/ergast/f1
REQUEST_TIMEOUT_SECONDS=15
USER_AGENT="pit-wall-insight-ingestion/0.1 (+https://github.com/pit-wall-insight)"

# --- Infrastructure: PostgreSQL (infrastructure/, docker-compose.yml) ---
# Single Postgres instance hosting both logical databases (raw + analytics).
POSTGRES_USER=pitwall
POSTGRES_PASSWORD=pitwall
# Created automatically by the official postgres image on first boot.
POSTGRES_DB=pit_wall_insight_raw
# Additional comma-separated databases created by infrastructure/docker/postgres/init/01-create-multiple-databases.sh
POSTGRES_MULTIPLE_DATABASES=pit_wall_insight_analytics
POSTGRES_PORT=5432

# --- Infrastructure: pgAdmin (docker-compose.yml) ---
PGADMIN_DEFAULT_EMAIL=admin@pitwallinsight.dev
PGADMIN_DEFAULT_PASSWORD=pitwall
PGADMIN_PORT=5050
